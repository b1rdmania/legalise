# Frontend build-time env vars.
#
# Vite reads VITE_-prefixed vars at build time and inlines them. Set
# these on the Pages project for the live deploy; leave unset for the
# compose-network dev tree where Vite proxies /api to the backend.

# Absolute API root for split deploys (frontend + backend on
# different origins). Must include the `/api` suffix.
# VITE_API_BASE_URL=https://api.legalise.dev/api
