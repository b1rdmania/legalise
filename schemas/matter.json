{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legalise.dev/schemas/matter.json",
  "title": "Matter",
  "description": "Legalise matter schema. Compatible with the Stella matter folder convention so a matter can move between workspaces without translation.",
  "type": "object",
  "required": ["slug", "title", "status", "privilege_posture"],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "URL-safe identifier; folder name on disk."
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "archived"]
    },
    "parties": {
      "type": "object",
      "properties": {
        "client": { "type": "string" },
        "opposing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "additional": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "case_theory": { "type": "string" },
    "pivot_fact": { "type": "string" },
    "privilege_posture": {
      "type": "string",
      "enum": ["A_cleared", "B_mixed", "C_paused"]
    },
    "default_model_id": {
      "type": "string",
      "description": "Provider/model identifier. e.g. 'claude-opus-4-7', 'ollama/llama3.1:70b'."
    },
    "opened_at": { "type": "string", "format": "date" },
    "closed_at": { "type": ["string", "null"], "format": "date" },
    "retention_until": { "type": ["string", "null"], "format": "date" },
    "proceedings_ref": {
      "type": ["string", "null"],
      "description": "If matter is in active proceedings (claim number, ET case reference)."
    },
    "side": {
      "type": ["string", "null"],
      "enum": ["claimant", "defendant", "respondent", "applicant", null]
    },
    "key_dates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "date"],
        "properties": {
          "label": { "type": "string" },
          "date": { "type": "string", "format": "date" }
        }
      }
    }
  },
  "additionalProperties": false
}
