# Copy to .env and fill in values. Everything is optional for local
# dev except SESSION_SECRET in deployed environments. The defaults
# in `backend/app/core/config.py` cover a clean `docker compose up`.

# Environment
ENVIRONMENT=development
DEBUG=true

# AI providers. Set what you have. Local Ollama works without keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://ollama:11434

# Default model. anthropic | openai | ollama identifier.
DEFAULT_MODEL_ID=claude-opus-4-7

# Auth + sessions (fastapi-users cookie + DB-backed access tokens).
# Generate SESSION_SECRET via: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-in-deployment
SESSION_COOKIE_NAME=legalise_session
SESSION_COOKIE_SECURE=false

# Per-user provider-key encryption (AES-256-GCM). 32-byte secret,
# base64url-encoded. If unset and ALLOW_SERVER_KEY_FALLBACK=true the
# server key from ANTHROPIC_API_KEY/OPENAI_API_KEY is used instead.
LEGALISE_KEY_ENCRYPTION_SECRET=
LEGALISE_ALLOW_SERVER_KEY_FALLBACK=true

# Email (Resend). Verification + password reset. Leave blank in dev;
# the verify link is logged to stdout instead.
RESEND_API_KEY=
EMAIL_FROM=Legalise <no-reply@legalise.dev>
EMAIL_VERIFY_URL_BASE=http://localhost:3000/#/auth/verify
PASSWORD_RESET_URL_BASE=http://localhost:3000/#/auth/reset

# Plugin substrate. PLUGINS_HOST_PATH is read by docker-compose to
# bind-mount the claude-for-uk-legal checkout into the backend
# container at /plugins. PLUGINS_REPO/_REF show up in the Modules
# page and the public catalogue.
PLUGINS_HOST_PATH=../../claude-for-uk-legal
PLUGINS_REPO=https://github.com/b1rdmania/claude-for-uk-legal
PLUGINS_REPO_REF=

# Public module submissions. Disabled if any of these are blank.
# TURNSTILE_* gate the POST; GITHUB_SUBMISSION_TOKEN opens the draft PR
# on b1rdmania/claude-for-uk-legal (PAT scoped to that repo only).
SUBMISSION_ENABLED=true
GITHUB_SUBMISSION_TOKEN=
GITHUB_SUBMISSION_REPO=b1rdmania/claude-for-uk-legal
GITHUB_SUBMISSION_BASE_BRANCH=main
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
SUBMISSION_RATE_LIMIT_PER_HOUR=5

# CORS. Comma-separated origins. Default includes legalise.dev and
# the local docker compose frontend on :3000.
# CORS_ORIGINS=http://localhost:3000,https://legalise.dev
