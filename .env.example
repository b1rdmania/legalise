# Copy to .env and fill in values.

ENVIRONMENT=development
DEBUG=true

# AI providers (cloud — set what you have; local Ollama works without keys)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Auth (stub — set anything in dev; v0.2 swaps to WorkOS / Stytch)
SESSION_SECRET=change-me-in-deployment

# Default model — anthropic | openai | ollama identifier
DEFAULT_MODEL_ID=claude-opus-4-7
