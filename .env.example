# Legalise — local fork environment.
#
# Copy to .env and adjust. Every variable here has a working default
# inside `infra/docker-compose.yml` for a fresh fork; this file
# documents what each one controls and which decisions you have to
# make. The only decision required for the Khan v Acme demo is
# whether you want a real provider key (Anthropic / OpenAI) or are
# happy running the keyless stub-echo model.
#
# Phase 16 (release readiness) treats this file as the canonical
# answer to "what env do I need" — if a variable affects local fork
# behaviour, it lives here with a default and a one-line explanation.

# =====================================================================
# REQUIRED — these have defaults baked into compose, but a fork that
# overrides any of them must override here so backend, worker, and
# `legalise doctor` all see the same value.
# =====================================================================

ENVIRONMENT=development
DEBUG=true

# Postgres DSN. Compose interpolates `${POSTGRES_DSN:-…}` into both
# backend and worker, so a host override here is honoured. Default
# matches the pgvector service in `infra/docker-compose.yml`.
POSTGRES_DSN=postgresql+psycopg://legalise:legalise@db:5432/legalise

# Redis. Used for the worker queue. Compose default.
REDIS_URL=redis://redis:6379/0

# Object storage — MinIO in compose; S3-compatible in hosted.
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=legalise
S3_SECRET_KEY=legalisesecret
S3_BUCKET=legalise-docs
S3_REGION=eu-west-2

# CORS allow-list. JSON array. Backend reads this as the literal
# allow-list for credentialed cross-origin fetches. Default covers
# the compose frontend on :3000 and the live demo origin. Add your
# preview/staging origin if you serve the frontend from elsewhere.
CORS_ORIGINS=["http://localhost:3000","https://legalise.dev"]

# Per-user provider-key encryption (AES-256-GCM). 32-byte secret as
# exactly 64 hex characters. Required for BYO key storage.
#
# LEAVE THIS EMPTY for local dev/eval: the backend generates a random
# key on boot so the stack comes up with no setup. The tradeoff is that
# stored provider keys won't survive a restart (re-add them in Settings).
# A NON-EMPTY value that isn't valid 64-hex makes the backend refuse to
# boot, so do not put a placeholder here.
#
# For anything real, set a stable value (production refuses to boot
# without one). Generate via:
#   python -c "import secrets; print(secrets.token_hex(32))"
LEGALISE_KEY_ENCRYPTION_SECRET=

# agent-kit eval adapter (POST /api/evals/agent) shared secret. Unset =
# endpoint disabled (503). Set to any value to enable the deterministic
# eval harness; the agent-kit runner sends it in X-Agent-Kit-Secret.
AGENT_KIT_SECRET=

# Retention enforcement. When true, the worker runs a daily sweep that
# PURGES matters past their retention_until via the audited tombstone.
# OFF by default (it deletes data — preview first with
# `python -m app.tools.retention_sweep`). LIMIT caps matters purged per
# run (longest-lapsed first); HOUR is the UTC hour of the daily run.
LEGALISE_RETENTION_SWEEP_ENABLED=false
LEGALISE_RETENTION_SWEEP_LIMIT=50
LEGALISE_RETENTION_SWEEP_HOUR=3

# Cookie session secret. Signs short-lived JWTs for email-verify /
# password-reset; session cookies themselves are DB-backed. Generate
# via: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-in-deployment
SESSION_COOKIE_NAME=legalise_session
SESSION_COOKIE_SECURE=false

# =====================================================================
# OPTIONAL — model providers. With all three unset, the keyless
# `stub-echo` model still runs the Khan demo end-to-end. Set what
# you have.
# =====================================================================

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://ollama:11434
DEFAULT_MODEL_ID=claude-sonnet-4-6

# Server-key fallback is dev-only: model_gateway refuses to fall back
# outside dev environments even when this flag is true. Production
# posture is BYO user keys; do not set ANTHROPIC_API_KEY / OPENAI_API_KEY
# in prod secrets — their absence is self-documenting.
LEGALISE_ALLOW_SERVER_KEY_FALLBACK=false

# Local/eval demo defaults. Firm role gates are dormant by default so
# any signed-in evaluator can run B_mixed demo matters. In dev only,
# the first registered user is promoted to workspace_admin automatically;
# production ignores the auto-admin flag even if it is accidentally set.
LEGALISE_FIRM_ROLE_GATES_ENABLED=false
LEGALISE_DEV_AUTO_ADMIN_FIRST_USER=true

# Optional quickstart acceleration. When true, scripts/quickstart.sh adds
# infra/docker-compose.prebuilt.yml and pulls GHCR backend/frontend
# images instead of building those two images locally.
LEGALISE_USE_PREBUILT_IMAGES=false
LEGALISE_BACKEND_IMAGE=ghcr.io/b1rdmania/legalise-backend:latest
LEGALISE_FRONTEND_IMAGE=ghcr.io/b1rdmania/legalise-frontend:latest

# =====================================================================
# OPTIONAL — outbound integrations. All degrade safely when blank.
# =====================================================================

# Email (Resend). Blank in dev → verify link logged to backend stdout.
RESEND_API_KEY=
EMAIL_FROM=Legalise <no-reply@legalise.dev>
EMAIL_VERIFY_URL_BASE=http://localhost:3000/#/auth/verify
PASSWORD_RESET_URL_BASE=http://localhost:3000/#/auth/reset

# Optional GitHub token for the skill importers (Lawve, GitHub repo).
# Read-only use — raises the GitHub API rate limit. Blank works.
GITHUB_READ_TOKEN=

# =====================================================================
# FRONTEND — Vite build-time vars are baked when the frontend image
# builds. For a local fork running through compose,
# `VITE_HOSTED_ACCESS_MODE=open` is set in the frontend service block
# of `infra/docker-compose.yml` so signup is enabled by default.
# Override here only if you build the frontend outside compose.
# =====================================================================

# VITE_HOSTED_ACCESS_MODE=open
# VITE_API_BASE_URL=http://localhost:8000/api
